# GhostFactory Observability — environment variables

# ⚠️ IMPORTANT: Always deploy with MIX_ENV=prod
# Running in :dev mode exposes a known fallback API key ("dev-secret-change-me").
# The Docker Compose setup uses MIX_ENV=prod by default — do not override it.

# ── Production (required; config/runtime.exs fail-fast if missing) ───────────

# Bearer token for /ingest and /v1/traces authentication
GF_API_KEY=your-secret-key-here

# Optional: protect /trail + /eval from public access (metadata: run_ids, span names, timings)
# Password = GF_API_KEY. Default off. Recommended for internet-facing deployments.
# TRAIL_AUTH_ENABLED=false

# Phoenix secret key base (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=your-secret-key-base-here

# Postgres connection (GF-704)
DATABASE_URL=ecto://user:pass@host/database

# Optional (prod): connection pool size (default 10)
# POOL_SIZE=10

# Optional: rate limit configuration (defaults shown)
# RATE_LIMIT_PERIOD_MS=60000
# RATE_LIMIT_COUNT=1000

# ── Dev / test (GF-704: .env auto-loaded via Dotenvy in :dev/:test) ──────────
# .env is gitignored; these are read by config/runtime.exs. OS env overrides .env.

# Postgres password for the dev/test Repo (default "postgres" if unset)
# PGPASSWORD=postgres

# Broadway batch flush timeout in ms (GF-777; default 100). Lower = lower p99
# latency + higher flush frequency. Ignored in :test (seam pinned to 50ms).
# BATCH_FLUSH_TIMEOUT_MS=100

# ── Docker Compose (GF-783) ──────────────────────────────────────────────────
# Required for `docker compose up` — plus GF_API_KEY and SECRET_KEY_BASE from the
# Production section above (same vars, defined once there):
POSTGRES_PASSWORD=change_me_strong_password
PHX_HOST=localhost  # or your domain when behind a reverse proxy

# Domain for Caddy TLS (GF-769). localhost uses a local CA; production: your real
# domain (e.g. spanchain.dev) → Caddy auto-provisions a Let's Encrypt cert.
DOMAIN=localhost

# Optional tuning
POOL_SIZE=10                  # Ecto DB connection pool
BATCH_FLUSH_TIMEOUT_MS=100    # Broadway flush interval (ms)

# Postgres TLS (default: OFF). The compose Postgres has no SSL, so leave unset.
# Set DATABASE_SSL=true only for a managed/remote Postgres that requires TLS.
# DATABASE_SSL=false

# Performance vs. integrity tradeoff (default: OFF — integrity first)
# Span Chain is a tamper-evident audit trail. synchronous_commit=off
# risks losing the last ~100ms of data on hard crash.
# verify_ledger will report a broken chain for those lost entries.
# Enable ONLY for non-compliance, high-throughput workloads where
# occasional data loss is acceptable.
#
# To enable: uncomment and add to docker-compose.yml postgres.command:
#   - "-c"
#   - "synchronous_commit=off"
